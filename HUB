-- Draggable
local dragging = false
local dragStart, startPos

Container.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Container.Position
    end
end)

Container.InputEnded:Connect(function()
    dragging = false
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Container.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Speed Limiter Function
local function EnableSpeedLimiter()
    if SpeedConnection then SpeedConnection:Disconnect() end
    
    SpeedConnection = RunService.Heartbeat:Connect(function()
        if not IsActive then return end
        
        local Char = LocalPlayer.Character
        if not Char then return end
        
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if not Hum then return end
        
        -- Enforce max speed strictly
        if Hum.WalkSpeed > MaxSpeed then
            Hum.WalkSpeed = MaxSpeed
        end
    end)
end

local function DisableSpeedLimiter()
    if SpeedConnection then
        SpeedConnection:Disconnect()
        SpeedConnection = nil
    end
end

-- Core Desync Function (NO RB, NO FastRespawn)
local function StartDesync()
    local Char = LocalPlayer.Character
    if not Char then 
        Notify("الشخصية غير موجودة")
        return false
    end
    
    local HRP = Char:WaitForChild("HumanoidRootPart", 3)
    if not HRP then
        Notify("HRP غير موجود")
        return false
    end
    
    -- Save fake position (current location)
    FakePos = HRP.Position
    IsActive = true
    
    -- Enable speed limiter
    EnableSpeedLimiter()
    
    -- Set initial speed
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if Hum and Hum.WalkSpeed > MaxSpeed then
        Hum.WalkSpeed = MaxSpeed
    end
    
    Notify("Desync مفعل! الحد: " .. MaxSpeed)
    
    -- Main desync loop - NO RB, just pure desync
    local lastUpdate = tick()
    
    DesyncConnection = RunService.Heartbeat:Connect(function()
        if not IsActive then return end
        
        -- Rate limiting
        if tick() - lastUpdate < UpdateRate then return end
        lastUpdate = tick()
        
        local Character = LocalPlayer.Character
        if not Character then return end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Root or not Humanoid then return end
        
        -- Enforce speed limit
        if Humanoid.WalkSpeed > MaxSpeed then
            Humanoid.WalkSpeed = MaxSpeed
        end
        
        -- Send fake position to server
        if FakePos then
            pcall(function()
                -- Small jitter for anti-detection
                local jitter = Vector3.new(
                    (math.random() - 0.5) * 0.2,
                    0,
                    (math.random() - 0.5) * 0.2
                )
                
                Root.CFrame = CFrame.new(FakePos + jitter)
                
                -- Network override if available
                if sethiddenproperty then
                    sethiddenproperty(Root, "NetworkPosition", FakePos)
                end
            end)
        end
    end)
    
    return true
end

local function StopDesync()
    IsActive = false
    FakePos = nil
    
    if DesyncConnection then
        DesyncConnection:Disconnect()
        DesyncConnection = nil
    end
    
    DisableSpeedLimiter()
    Notify("Desync متوقف")
end

-- Toggle Handler
ToggleBtn.MouseButton1Click:Connect(function()
    if IsActive then
        StopDesync()
        ToggleBtn.Text = "تشغيل"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    else
        local success = StartDesync()
        if success then
            ToggleBtn.Text = "إيقاف"
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
        end
    end
end)

-- Speed Input Handler
SpeedBox.FocusLost:Connect(function()
    local newSpeed = tonumber(SpeedBox.Text)
    if newSpeed then
        -- Limit to safe range (16-28)
        if newSpeed < 16 then newSpeed = 16 end
        if newSpeed > 28 then newSpeed = 28 end
        
        MaxSpeed = newSpeed
        SpeedBox.Text = tostring(MaxSpeed)
        SpeedLabel.Text = "الحد: " .. MaxSpeed
        
        -- Apply immediately if active
        if IsActive then
            local Char = LocalPlayer.Character
            if Char then
                local Hum = Char:FindFirstChildOfClass("Humanoid")
                if Hum then
                    Hum.WalkSpeed = MaxSpeed
                end
            end
        end
        
        Notify("الحد الجديد: " .. MaxSpeed)
    else
        SpeedBox.Text = tostring(MaxSpeed)
    end
end)

-- Auto-restore on respawn
LocalPlayer.CharacterAdded:Connect(function()
    if IsActive then
        task.wait(0.3)
        StartDesync()
    end
end)

-- Initial notification
Notify("FR HUB جاهز! الحد: " .. MaxSpeed)

-- Make button draggable
local dragging = false
local dragStart, startPos

MainButton.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainButton.Position
    end
end)

MainButton.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        MainButton.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Core Desync Function - Ultra Optimized
local function EnableDesync()
    local Character = LocalPlayer.Character
    if not Character then return end
    
    local Humanoid = Character:FindFirstChildOfClass("Humanoid")
    local HRP = Character:FindFirstChild("HumanoidRootPart")
    if not Humanoid or not HRP then return end
    
    -- Store initial position
    LastRealPosition = HRP.CFrame
    FakePosition = HRP.Position
    
    -- Create visualizer (optional, lightweight)
    if Visualizer then Visualizer:Destroy() end
    Visualizer = Instance.new("Part")
    Visualizer.Name = "DesyncVisual"
    Visualizer.Size = Vector3.new(4, 6, 4)
    Visualizer.Anchored = true
    Visualizer.CanCollide = false
    Visualizer.Transparency = 0.7
    Visualizer.Color = Color3.fromRGB(0, 255, 100)
    Visualizer.Material = Enum.Material.Neon
    Visualizer.CFrame = HRP.CFrame
    Visualizer.Parent = Workspace
    
    -- Create label
    if VisualizerLabel then VisualizerLabel:Destroy() end
    VisualizerLabel = Instance.new("BillboardGui")
    VisualizerLabel.Size = UDim2.new(0, 100, 0, 40)
    VisualizerLabel.AlwaysOnTop = true
    VisualizerLabel.Adornee = Visualizer
    VisualizerLabel.Parent = Visualizer
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = "FAKE POS"
    Label.TextColor3 = Color3.fromRGB(0, 255, 100)
    Label.TextSize = 14
    Label.Font = Enum.Font.GothamBold
    Label.Parent = VisualizerLabel
    
    -- Ultra-fast desync loop
    Connection = RunService.Heartbeat:Connect(function()
        if not DesyncEnabled then return end
        
        local Char = LocalPlayer.Character
        if not Char then return end
        
        local Root = Char:FindFirstChild("HumanoidRootPart")
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if not Root or not Hum then return end
        
        -- Get real position
        local RealPos = Root.Position
        local RealCFrame = Root.CFrame
        
        -- Update fake position (frozen at activation point with small offset for realism)
        if FakePosition then
            -- Send fake position to server continuously
            for i = 1, 3 do -- Multiple sends for reliability
                -- Method 1: Direct network manipulation
                pcall(function()
                    if getconnections then
                        for _, v in pairs(getconnections(RunService.Heartbeat)) do
                            if v.Function then
                                local info = debug.getinfo(v.Function)
                                if info and info.name and (info.name:find("replicate") or info.name:find("network")) then
                                    -- Found network replication
                                end
                            end
                        end
                    end
                end)
                
                -- Method 2: Physics manipulation
                pcall(function()
                    local oldVelocity = Root.Velocity
                    Root.Velocity = Vector3.new(0, 0, 0)
                    Root.CFrame = CFrame.new(FakePosition) * CFrame.Angles(0, math.random() * 0.1, 0)
                    Root.Velocity = oldVelocity
                end)
                
                -- Method 3: Direct CFrame setting with replication
                pcall(function()
                    Root.CFrame = CFrame.new(FakePosition + Vector3.new(math.random(-1, 1), 0, math.random(-1, 1)) * 0.1)
                end)
            end
            
            -- Update visualizer
            if Visualizer and Visualizer.Parent then
                Visualizer.CFrame = CFrame.new(FakePosition)
            end
        end
    end)
    
    -- Additional RenderStepped for smooth visuals
    VelocityTracker = RunService.RenderStepped:Connect(function()
        if not DesyncEnabled then return end
        local Char = LocalPlayer.Character
        if not Char then return end
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if Root and FakePosition then
            -- Keep player fully controllable
            -- No velocity restrictions - full freedom
        end
    end)
end

local function DisableDesync()
    if Connection then
        Connection:Disconnect()
        Connection = nil
    end
    if VelocityTracker then
        VelocityTracker:Disconnect()
        VelocityTracker = nil
    end
    if Visualizer then
        Visualizer:Destroy()
        Visualizer = nil
    end
    if VisualizerLabel then
        VisualizerLabel:Destroy()
        VisualizerLabel = nil
    end
    FakePosition = nil
    LastRealPosition = nil
end

-- Toggle function
local function ToggleDesync()
    DesyncEnabled = not DesyncEnabled
    
    if DesyncEnabled then
        -- Enable
        MainButton.Text = "DESYNC: ON"
        MainButton.TextColor3 = Color3.fromRGB(0, 255, 100)
        Stroke.Color = Color3.fromRGB(0, 255, 100)
        
        TweenService:Create(MainButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(20, 50, 20)
        }):Play()
        
        Notify("FR HUB", "Desync مفعل! تحرك بحرية", 2)
        EnableDesync()
    else
        -- Disable
        MainButton.Text = "DESYNC: OFF"
        MainButton.TextColor3 = Color3.fromRGB(255, 80, 80)
        Stroke.Color = Color3.fromRGB(255, 80, 80)
        
        TweenService:Create(MainButton, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        }):Play()
        
        Notify("FR HUB", "Desync متوقف", 2)
        DisableDesync()
    end
end

MainButton.MouseButton1Click:Connect(ToggleDesync)


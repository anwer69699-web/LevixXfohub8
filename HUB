-- Draggable Frame
local dragging = false
local dragStart, startPos

Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Frame.Position
    end
end)

Frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- CORE DESYNC FUNCTION
local function StartDesync()
    local Character = LocalPlayer.Character
    if not Character then 
        Notify("الشخصية غير موجودة")
        return false
    end
    
    local HRP = Character:WaitForChild("HumanoidRootPart", 3)
    if not HRP then
        Notify("لم يتم العثور على HRP")
        return false
    end
    
    -- Save fake position
    FakePos = HRP.Position
    IsActive = true
    
    Notify("الاختفاء مفعل! تحرك بحرية")
    
    -- Main loop using Heartbeat but with controlled rate
    local lastUpdate = tick()
    
    LoopConnection = RunService.Heartbeat:Connect(function()
        if not IsActive then return end
        
        -- Control update rate manually
        if tick() - lastUpdate < Settings.UpdateRate then return end
        lastUpdate = tick()
        
        local Char = LocalPlayer.Character
        if not Char then return end
        
        local Root = Char:FindFirstChild("HumanoidRootPart")
        if not Root then return end
        
        -- Send fake position
        pcall(function()
            -- Add tiny jitter
            local jitterX = (math.random() - 0.5) * Settings.PositionJitter
            local jitterZ = (math.random() - 0.5) * Settings.PositionJitter
            local FakeWithJitter = FakePos + Vector3.new(jitterX, 0, jitterZ)
            
            -- Method 1: Set CFrame directly
            Root.CFrame = CFrame.new(FakeWithJitter)
            
            -- Method 2: Network spoof (if supported)
            if sethiddenproperty then
                sethiddenproperty(Root, "NetworkPosition", FakePos)
            end
        end)
    end)
    
    return true
end

local function StopDesync()
    IsActive = false
    FakePos = nil
    
    if LoopConnection then
        LoopConnection:Disconnect()
        LoopConnection = nil
    end
    
    Notify("الاختفاء متوقف")
end

-- Toggle handler
Toggle.MouseButton1Click:Connect(function()
    if IsActive then
        -- Turn off
        StopDesync()
        Toggle.Text = "تفعيل الاختفاء"
        Toggle.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    else
        -- Turn on
        local success = StartDesync()
        if success then
            Toggle.Text = "إيقاف الاختفاء"
            Toggle.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
        end
    end
end)

-- Auto-restore on respawn
LocalPlayer.CharacterAdded:Connect(function(newChar)
    if IsActive then
        task.wait(0.5)
        -- Reset fake position to new spawn location
        local HRP = newChar:WaitForChild("HumanoidRootPart", 3)
        if HRP then
            FakePos = HRP.Position
            Notify("تم استعادة الاختفاء")
        end
    end
end)


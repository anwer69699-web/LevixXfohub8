    Label.TextColor3 = Color3.fromRGB(0, 255, 150)
    Label.TextSize = 14
    Label.Font = Enum.Font.GothamBold
    Label.Parent = VisualizerLabel
end

local function DestroyVisualizer()
    if Visualizer then Visualizer:Destroy() end
    if VisualizerLabel then VisualizerLabel:Destroy() end
    Visualizer = nil
    VisualizerLabel = nil
end

local function UpdateVisualizer(position)
    if Visualizer then
        Visualizer.CFrame = CFrame.new(position)
    end
end

-- Speed Lock Function (Mode 1)
local function EnableSpeedLock()
    if SpeedConnection then SpeedConnection:Disconnect() end

    SpeedConnection = RunService.Heartbeat:Connect(function()
        if DesyncMode ~= 1 then return end

        local Char = LocalPlayer.Character
        if not Char then return end

        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if not Hum then return end

        -- Lock speed to 14 always
        if Hum.WalkSpeed ~= TargetSpeed then
            Hum.WalkSpeed = TargetSpeed
        end
    end)
end

local function DisableSpeedLock()
    if SpeedConnection then
        SpeedConnection:Disconnect()
        SpeedConnection = nil
    end
end

-- Main Desync Function
local function EnableDesync(mode)
    DesyncMode = mode
    local Char = LocalPlayer.Character
    if not Char then return end

    local HRP = Char:FindFirstChild("HumanoidRootPart")
    if not HRP then return end

    -- Store fake position
    FakePosition = HRP.Position

    -- Create visualizer
    CreateVisualizer()
    UpdateVisualizer(FakePosition)

    -- Enable speed lock if mode 1
    if mode == 1 then
        EnableSpeedLock()
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if Hum then
            Hum.WalkSpeed = TargetSpeed
        end
    end

    -- Main desync loop
    if Connection then Connection:Disconnect() end

    Connection = RunService.Heartbeat:Connect(function()
        if DesyncMode == 0 then return end

        local Character = LocalPlayer.Character
        if not Character then return end

        local Root = Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Root or not Humanoid then return end

        -- Mode 1: Force speed 14 always
        if DesyncMode == 1 then
            if Humanoid.WalkSpeed ~= TargetSpeed then
                Humanoid.WalkSpeed = TargetSpeed
            end
        end

        -- Send fake position to server
        if FakePosition then
            for i = 1, 2 do
                pcall(function()
                    local oldCFrame = Root.CFrame
                    local oldVelocity = Root.Velocity

                    Root.CFrame = CFrame.new(FakePosition + Vector3.new(
                        math.random(-2, 2) * 0.1, 
                        0, 
                        math.random(-2, 2) * 0.1
                    ))
                    Root.Velocity = Vector3.new(0, 0, 0)

                    task.wait()

                    Root.CFrame = oldCFrame
                    Root.Velocity = oldVelocity
                end)

                pcall(function()
                    sethiddenproperty(Root, "NetworkPosition", FakePosition)
                    sethiddenproperty(Root, "ReplicationPosition", FakePosition)
                end)
            end

            UpdateVisualizer(FakePosition)
        end
    end)
end

local function DisableAll()
    DesyncMode = 0
    if Connection then
        Connection:Disconnect()
        Connection = nil
    end
    DisableSpeedLock()
    DestroyVisualizer()
    FakePosition = nil
end


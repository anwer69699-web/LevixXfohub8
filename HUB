-- FR HUB | Ultra Speed Desync - Extreme Performance Edition
-- Handles massive speeds with ZERO lag
-- No speed restrictions - Pure performance

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local StarterGui = game:GetService("StarterGui")

-- Ultra-optimized settings
local Settings = {
    UpdateRate = 0.05,      -- 20 FPS - Perfect balance for speed vs performance
    PositionJitter = 0.5,   -- Small random offset for anti-detection
}

-- State
local IsActive = false
local FakePos = nil
local Thread = nil

-- Ultra-light notification
local function Notify(text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = "FR HUB",
            Text = text,
            Duration = 1.5
        })
    end)
end

-- Prevent double load
if _G.FRHUB_ULTRA_SPEED then return end
_G.FRHUB_ULTRA_SPEED = true

-- Minimal GUI - Single button
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "FRHUB_Ultra"
ScreenGui.ResetOnSpawn = false
ScreenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

local Toggle = Instance.new("TextButton")
Toggle.Size = UDim2.new(0, 100, 0, 40)
Toggle.Position = UDim2.new(0.9, -50, 0.5, -20)
Toggle.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
Toggle.Text = "OFF"
Toggle.TextColor3 = Color3.fromRGB(255, 50, 50)
Toggle.TextSize = 16
Toggle.Font = Enum.Font.GothamBold
Toggle.Parent = ScreenGui

Instance.new("UICorner", Toggle).CornerRadius = UDim.new(0, 8)

-- Draggable
local drag, dragStart, startPos = false, nil, nil
local UserInputService = game:GetService("UserInputService")

Toggle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        drag = true
        dragStart = input.Position
        startPos = Toggle.Position
    end
end)

Toggle.InputEnded:Connect(function() drag = false end)

RunService.RenderStepped:Connect(function()
    if drag and UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
        local delta = UserInputService:GetMouseLocation() - dragStart
        Toggle.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, 
                                      startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- CORE: Ultra-fast desync engine
local function UltraDesync()
    local Character = LocalPlayer.Character
    if not Character then return end
    
    local HRP = Character:FindFirstChild("HumanoidRootPart")
    if not HRP then return end
    
    -- Capture position once
    FakePos = HRP.Position

    -- Ultra-lightweight thread
    Thread = task.spawn(function()
        while IsActive do
            local Char = LocalPlayer.Character
            if not Char then task.wait(Settings.UpdateRate) continue end
            
            local Root = Char:FindFirstChild("HumanoidRootPart")
            if not Root then task.wait(Settings.UpdateRate) continue end
            
            -- Method 1: Direct position spoof (fastest)
            pcall(function()
                local Jitter = Vector3.new(
                    math.random(-10, 10) * 0.01,
                    0,
                    math.random(-10, 10) * 0.01
                ) * Settings.PositionJitter
                
                Root.CFrame = CFrame.new(FakePos + Jitter)
            end)
            
            -- Method 2: Network override (if available)
            pcall(function()
                sethiddenproperty(Root, "NetworkPosition", FakePos)
            end)
            
            task.wait(Settings.UpdateRate)
        end
    end)
end

local function StopDesync()
    IsActive = false
    FakePos = nil
    Thread = nil
end

-- Toggle handler
Toggle.MouseButton1Click:Connect(function()
    IsActive = not IsActive
    
    if IsActive then
        Toggle.Text = "ON"
        Toggle.TextColor3 = Color3.fromRGB(0, 255, 100)
        Toggle.BackgroundColor3 = Color3.fromRGB(10, 40, 10)
        Notify("Desync Active - Extreme Speed Ready!")
        UltraDesync()
    else
        Toggle.Text = "OFF"
        Toggle.TextColor3 = Color3.fromRGB(255, 50, 50)
        Toggle.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
        Notify("Desync Stopped")
        StopDesync()
    end
end)

-- Auto-restore on death
LocalPlayer.CharacterAdded:Connect(function()
    if IsActive then
        task.wait(0.2)
        UltraDesync()
    end
end)

Notify("FR HUB Ultra - Ready for Extreme Speeds!")

-- Speed Limiter
local function EnableSpeedLimiter()
    if SpeedConnection then SpeedConnection:Disconnect() end
    
    SpeedConnection = RunService.Heartbeat:Connect(function()
        if not IsActive then return end
        
        local Char = LocalPlayer.Character
        if not Char then return end
        
        local Hum = Char:FindFirstChildOfClass("Humanoid")
        if not Hum then return end

        if Hum.WalkSpeed > MaxSpeed then
            Hum.WalkSpeed = MaxSpeed
        end
    end)
end

local function DisableSpeedLimiter()
    if SpeedConnection then
        SpeedConnection:Disconnect()
        SpeedConnection = nil
    end
end

-- Core Desync (NO kill, NO RB, just pure desync)
local function StartDesync()
    local Char = LocalPlayer.Character
    if not Char then 
        Notify("FR HUB", "الشخصية غير موجودة")
        return false
    end
    
    local HRP = Char:WaitForChild("HumanoidRootPart", 3)
    if not HRP then
        Notify("FR HUB", "HRP غير موجود")
        return false
    end
    
    FakePos = HRP.Position
    IsActive = true
    
    EnableSpeedLimiter()
    
    -- Set speed immediately
    local Hum = Char:FindFirstChildOfClass("Humanoid")
    if Hum and Hum.WalkSpeed > MaxSpeed then
        Hum.WalkSpeed = MaxSpeed
    end
    
    Notify("FR HUB", "Desync مفعل | الحد: " .. MaxSpeed)
    
    -- Main loop - Clean and fast
    local lastUpdate = tick()
    
    DesyncConnection = RunService.Heartbeat:Connect(function()
        if not IsActive then return end
        
        if tick() - lastUpdate < UpdateRate then return end
        lastUpdate = tick()
        
        local Character = LocalPlayer.Character
        if not Character then return end
        
        local Root = Character:FindFirstChild("HumanoidRootPart")
        local Humanoid = Character:FindFirstChildOfClass("Humanoid")
        if not Root or not Humanoid then return end
        
        -- Strict speed limit
        if Humanoid.WalkSpeed > MaxSpeed then
            Humanoid.WalkSpeed = MaxSpeed
        end
        
        -- Send fake position
        if FakePos then
            pcall(function()
                local jitter = Vector3.new(
                    (math.random() - 0.5) * 0.15,
                    0,
                    (math.random() - 0.5) * 0.15
                )
                
                Root.CFrame = CFrame.new(FakePos + jitter)
                
                if sethiddenproperty then
                    sethiddenproperty(Root, "NetworkPosition", FakePos)
                end
            end)
        end
    end)
    
    return true
end

local function StopDesync()
    IsActive = false
    FakePos = nil
    
    if DesyncConnection then
        DesyncConnection:Disconnect()
        DesyncConnection = nil
    end
    
    DisableSpeedLimiter()
    Notify("FR HUB", "Desync متوقف")
end

-- Button 1 Handler: Toggle GUI
GuiToggleBtn.MouseButton1Click:Connect(function()
    GuiVisible = not GuiVisible
    SettingsFrame.Visible = GuiVisible
    
    if GuiVisible then
        GuiToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 100)
        TweenService:Create(SettingsFrame, TweenInfo.new(0.3), {Size = UDim2.new(0, 200, 0, 150)}):Play()
    else
        GuiToggleBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    end
end)

-- Button 2 Handler: Toggle Desync
DesyncBtn.MouseButton1Click:Connect(function()
    if IsActive then
        StopDesync()
        DesyncBtn.Text = "OFF"
        DesyncBtn.TextColor3 = Color3.fromRGB(255, 80, 80)
        DesyncBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    else
        local success = StartDesync()
        if success then
            DesyncBtn.Text = "ON"
            DesyncBtn.TextColor3 = Color3.fromRGB(0, 255, 100)
            DesyncBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 80)
        end
    end
end)

-- Speed Input Handler
SpeedInput.FocusLost:Connect(function()
    local newSpeed = tonumber(SpeedInput.Text)
    if newSpeed then
        if newSpeed < 16 then newSpeed = 16 end
        if newSpeed > 28 then newSpeed = 28 end
        
        MaxSpeed = newSpeed
        SpeedInput.Text = tostring(MaxSpeed)
        SpeedText.Text = "حد السرعة: " .. MaxSpeed
        
        if IsActive then
            local Char = LocalPlayer.Character
            if Char then
                local Hum = Char:FindFirstChildOfClass("Humanoid")
                if Hum then Hum.WalkSpeed = MaxSpeed end
            end
        end
        
        Notify("FR HUB", "الحد الجديد: " .. MaxSpeed)
    else
        SpeedInput.Text = tostring(MaxSpeed)
    end
end)

-- Auto-restore
LocalPlayer.CharacterAdded:Connect(function()
    if IsActive then
        task.wait(0.3)
        StartDesync()
    end
end)

